<% content_for :title, "Edit FAQ" %>

<%= render HeadingComponent.new(title: "Edit FAQ page", tone: :blue) %>

<div class="edit-faq-page">
  <%= form_with model: [:helper, @faq_page], local: true do |f| %>
    <div class="field">
      <%= f.text_area :body, rows: 20, class: "input-monospace" %>
    </div>

    <div class="actions">
      <%= f.submit "Save", class: "btn-primary" %>
    </div>
  <% end %>
</div>

<style>
  .edit-faq-page {
    margin-top: 1.5em;

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.5em;

      textarea {
        width: 100%;
        padding: 0.5em;
        border-radius: 4px;
        border: none;
        font-family: "Courier New", Courier, monospace;
        font-size: 1.25rem;
      }
    }

    .actions {
      margin-top: 1em;

      input[type="submit"] {
        background: var(--color-green-500);
        color: white;
        border: none;
        padding: 0.5em 1em;
        border-radius: 4px;
        cursor: pointer;
        font-size: 1.25rem;
      }
    }

    .audit-log {
      margin-top: 1em;
    }
  }
</style>
